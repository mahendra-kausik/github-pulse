# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=US                         # BigQuery/GCS multi-region; keep US for free-tier defaults
GCS_BUCKET=github-pulse-lake-CHANGE_ME # globally unique; matches terraform var

# BigQuery datasets (created by terraform)
BQ_DATASET_RAW=github_pulse_raw
BQ_DATASET_MARTS=github_pulse_marts
BQ_RAW_TABLE=events

# --- cost guardrail ---
# Max bytes a single dbt/BQ query may bill before it errors. 5 GB is generous for this dataset.
MAX_BYTES_BILLED=5000000000

# --- auth ---
# Local dev: leave this UNSET and use `gcloud auth application-default login` (ADC).
# Kestra-in-Docker: point at a mounted, gitignored service-account key.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# --- ingestion ---
DATA_DIR=./data                       # local scratch for downloaded .gz + parquet (gitignored)
